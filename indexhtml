<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FieldMaster • 2026</title>
<script src="https://unpkg.com/dexie@3.2.4/dist/dexie.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap');
:root { --bg:#070c1a; --accent:#00aaff; --accent2:#00ffcc; --text:#c8d8f0; --card:#0f1a2e; --border:#1e3050; }
* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--bg); color:var(--text); font-family:'Barlow',sans-serif; min-height:100dvh; }
.header { background:linear-gradient(135deg,#070c1a,#0d1528); padding:14px 16px; display:flex; align-items:center; gap:12px; border-bottom:1px solid #1e3050; position:sticky; top:0; z-index:100; }
.header-logo { font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; letter-spacing:4px; background:linear-gradient(90deg,#00aaff,#00ffcc); -webkit-background-clip:text; color:transparent; }
.tabs { display:flex; overflow-x:auto; background:#0d1528; border-bottom:1px solid #1e3050; padding:8px 0; gap:6px; }
.tab { padding:12px 20px; font-weight:700; font-size:13px; letter-spacing:1.5px; text-transform:uppercase; white-space:nowrap; border-bottom:3px solid transparent; transition:all 0.3s; }
.tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.page { display:none; padding:20px 16px 80px; }
.page.active { display:block; }
.card { background:var(--card); border:1px solid var(--border); border-radius:12px; margin-bottom:16px; padding:16px; }
</style>
</head>
<body>

<div class="header">
  <div class="header-logo">FIELD<span>MASTER</span></div>
</div>

<div class="tabs">
  <button class="tab active" onclick="showPage('home')">🏠 Início</button>
  <button class="tab" onclick="showPage('equip')">📸 Equipamentos</button>
  <button class="tab" onclick="showPage('manuais')">📖 Manuais</button>
  <button class="tab" onclick="showPage('diagnostico')">🔍 Diagnóstico IA</button>
  <button class="tab" onclick="showPage('backup')">💾 Backup</button>
  <button class="tab" onclick="showPage('glossario')">📖 Glossário</button>
  <button class="tab" onclick="showAdminTab()">🔐 Admin</button>
</div>

<!-- DIAGNÓSTICO IA - COM CÂMERA -->
<div class="page active" id="page-diagnostico">
  <h2 style="color:#00ffcc;margin-bottom:16px">🔍 Diagnóstico IA</h2>

  <div style="display:flex;gap:8px;margin-bottom:16px">
    <button onclick="buscarPorCodigo()" style="flex:1;padding:14px;background:#1e3050;color:#fff;border-radius:8px">🔎 Buscar por Código (Interno)</button>
    <button onclick="ativarCamera()" style="flex:1;padding:14px;background:#00aaff;color:#000;border-radius:8px">📷 Tirar Foto para IA</button>
  </div>

  <!-- Câmera -->
  <div id="cameraArea" style="display:none">
    <video id="cameraPreview" autoplay playsinline style="width:100%;max-height:300px;border-radius:12px;border:2px solid #00ffcc"></video>
    <div style="margin-top:12px;display:flex;gap:8px">
      <button onclick="capturarFoto()" style="flex:1;padding:14px;background:#00ffcc;color:#000;border-radius:8px">⊙ Capturar Foto</button>
      <button onclick="fecharCamera()" style="flex:1;padding:14px;background:#ff3355;color:#fff;border-radius:8px">Cancelar</button>
    </div>
  </div>

  <!-- Preview da foto capturada -->
  <div id="photoPreviewArea" style="display:none;margin-top:16px">
    <img id="capturedPhoto" style="width:100%;max-height:300px;border-radius:12px;border:3px solid #00ffcc">
    <button onclick="enviarFotoParaIA()" style="width:100%;margin-top:12px;padding:16px;background:linear-gradient(#00aaff,#00ffcc);color:#000;font-weight:900;border:none;border-radius:12px">🤖 Enviar Foto para IA</button>
  </div>

  <div id="diagnosticoResult" class="card" style="margin-top:16px;display:none"></div>
</div>

<script>
// ==================== BANCO DE DADOS ====================
const db = new Dexie('FieldMasterDB');
db.version(1).stores({ faults: 'code,name,type,causes,actions,drive' });

// ==================== FALHAS LOCAIS ====================
async function initFalhas() {
  const count = await db.faults.count();
  if (count === 0) {
    await db.faults.bulkAdd([
      {code:"F005", name:"Bus Overvoltage", type:"manual", causes:["Desaceleração rápida"], actions:["Verificar rampa"], drive:"Peak150"},
      {code:"F007", name:"Motor Overload", type:"auto", causes:["Sobrecarga"], actions:["Verificar corrente"], drive:"Peak150"},
      {code:"OverSpeed Trip", name:"OverSpeed Trip", type:"manual", causes:["Velocidade acima do limite"], actions:["Verificar setpoint"], drive:"Peak150"}
    ]);
  }
}

// ==================== BUSCAR POR CÓDIGO ====================
window.buscarPorCodigo = async function() {
  const code = prompt("Digite o código da falha (ex: F005):");
  if (!code) return;
  const resultDiv = document.getElementById('diagnosticoResult');
  resultDiv.style.display = 'block';

  const local = await db.faults.get(code.toUpperCase());
  if (local) {
    resultDiv.innerHTML = `<strong style="color:#00ffcc">✅ Encontrado no banco local</strong><br><strong>${local.name}</strong><br>Tipo: ${local.type}<br>Causas: ${local.causes.join(', ')}<br>Ações: ${local.actions.join(', ')}`;
  } else {
    resultDiv.innerHTML = `<strong style="color:#ff3355">❌ Falha não encontrada no banco local.<br>Chame a IA com foto se necessário.</strong>`;
  }
};

// ==================== CÂMERA ====================
let stream = null;
let capturedBase64 = null;

window.ativarCamera = async function() {
  try {
    stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });
    const video = document.getElementById('cameraPreview');
    video.srcObject = stream;
    document.getElementById('cameraArea').style.display = 'block';
    document.getElementById('photoPreviewArea').style.display = 'none';
  } catch(e) {
    alert("Câmera não disponível ou permissão negada.");
  }
};

window.capturarFoto = function() {
  const video = document.getElementById('cameraPreview');
  const canvas = document.createElement('canvas');
  canvas.width = video.videoWidth;
  canvas.height = video.videoHeight;
  canvas.getContext('2d').drawImage(video, 0, 0);
  capturedBase64 = canvas.toDataURL('image/jpeg', 0.85).split(',')[1];

  document.getElementById('capturedPhoto').src = 'data:image/jpeg;base64,' + capturedBase64;
  document.getElementById('photoPreviewArea').style.display = 'block';
  document.getElementById('cameraArea').style.display = 'none';
  if (stream) stream.getTracks().forEach(t => t.stop());
};

window.fecharCamera = function() {
  if (stream) stream.getTracks().forEach(t => t.stop());
  document.getElementById('cameraArea').style.display = 'none';
};

window.enviarFotoParaIA = async function() {
  if (!capturedBase64) return alert("Nenhuma foto capturada");
  const resultDiv = document.getElementById('diagnosticoResult');
  resultDiv.style.display = 'block';
  resultDiv.innerHTML = '<p style="color:#00ffcc">Enviando foto para IA...</p>';

  const prompt = `Você é especialista EXCLUSIVO em equipamentos Woodward (Peak 150, 505, DSLC-2), WEG geradores e Voith.
Analise a foto enviada.
Se for um desses equipamentos (display, nameplate, painel, etc.), responda normalmente.
Se NÃO for relacionado, responda EXATAMENTE esta frase e nada mais: 
"A foto não se refere aos equipamentos suportados pelo FieldMaster (Woodward Peak 150, 505, DSLC-2, WEG, Voith). Por favor, envie uma foto válida."`;

  try {
    const res = await fetch('https://powerflex-api-proxy.jamiscosta81.workers.dev', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        model: 'gemini-2.5-flash',
        messages: [{role:'user', content: [{type:'image', source:{type:'base64', media_type:'image/jpeg', data:capturedBase64}}, {type:'text', text:prompt}]}]
      })
    });
    const data = await res.json();
    const texto = data.content?.[0]?.text || '';
    resultDiv.innerHTML = texto.includes("não se refere") ? `<strong style="color:#ff3355">${texto}</strong>` : `<strong>🤖 IA:</strong><br>${texto}`;
  } catch(e) {
    resultDiv.innerHTML = `<strong style="color:#ff3355">Erro na conexão com IA</strong>`;
  }
};

// Inicialização
async function initApp() {
  await initFalhas();
  console.log("✅ FieldMaster carregado com câmera e busca interna");
}
initApp();
</script>
</body>
</html>
